# ========================================
# CONFIGURACIÓN DE CLAVES API
# ========================================
# Copia este archivo como .env y completa tus claves

# Tu API Key de Google Gemini (obtenerla en: https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=tu_clave_gemini_aqui
# Opcional: también puedes usar este nombre de variable
GEMINI_API_KEY=tu_clave_gemini_aqui

# Tu API Key de Groq (obtenerla en: https://console.groq.com/keys)
GROQ_API_KEY=tu_clave_groq_aqui

# Tu API Key de OpenAI (obtenerla en: https://platform.openai.com/api-keys)
OPENAI_API_KEY=tu_clave_openai_aqui

# Tu API Key de Anthropic/Claude (obtenerla en: https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=tu_clave_anthropic_aqui

# Proveedor de IA a usar: auto, groq, gemini, openai, anthropic
LLM_PROVIDER=auto

# Tu API Key de Groq (obtenerla en: https://console.groq.com/keys)
GROQ_API_KEY=tu_clave_groq_aqui

# Tu Steam API Key (obtenerla en: https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=tu_clave_steam_aqui

# Tu Steam ID de 64 bits (encontrarlo en: https://steamid.io/)
STEAM_USER_ID=tu_steam_id_aqui

# ========================================
# CONFIGURACIÓN DEL LLM (opcional)
# ========================================
# Proveedor: 'auto' (prueba groq → gemini), 'groq', o 'gemini'
# LLM_PROVIDER=auto
# LLM_MODEL_GROQ=llama-3.3-70b-versatile
# LLM_MODEL_GEMINI=gemini-2.0-flash
# LLM_TEMPERATURE=0.0

# ========================================
# OTROS (opcional)
# ========================================
# CACHE_TTL_SECONDS=300
# MAX_MEMORY_MESSAGES=10
# LOG_LEVEL=INFO
